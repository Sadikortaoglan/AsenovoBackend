# Database Configuration
POSTGRES_DB=sara_asansor
POSTGRES_USER=sara_asansor
POSTGRES_PASSWORD=your_secure_password_here

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-minimum-32-characters
QR_SECRET_KEY=your-qr-hmac-secret-key-change-this-in-production-minimum-32-characters

# Tenancy migration controls (single-tenant -> hybrid bootstrap)
TENANCY_MIGRATION_ENABLED=true
TENANCY_MIGRATION_INCLUDE_SHARED_SCHEMAS=true
TENANCY_MIGRATION_INCLUDE_DEDICATED_DBS=false
TENANCY_DEFAULT_SHARED_SCHEMA=public
TENANCY_FLYWAY_HISTORY_TABLE=flyway_schema_history
TENANCY_FLYWAY_BASELINE_ON_MIGRATE=true
TENANCY_FLYWAY_CONNECT_RETRIES=1

# CORS Configuration (comma-separated, supports wildcard patterns)
# Local multi-tenant FE example:
CORS_ALLOWED_ORIGINS=http://*.sara.local:5173,http://localhost:5173,http://127.0.0.1:5173
# Production example:
# CORS_ALLOWED_ORIGINS=https://*.app.yourdomain.com,https://admin.yourdomain.com

# Production backend environment template
# Copy on server as: /home/ec2-user/sara-backend/.env
# Then fill real secrets/hosts.

SPRING_PROFILES_ACTIVE=prod

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://REPLACE_DB_HOST:5432/sara
SPRING_DATASOURCE_USERNAME=sara
SPRING_DATASOURCE_PASSWORD=REPLACE_STRONG_DB_PASSWORD

# Security
JWT_SECRET=REPLACE_MIN_32_CHAR_SECRET
QR_SECRET_KEY=REPLACE_MIN_32_CHAR_SECRET

# CORS
CORS_ALLOWED_ORIGINS=https://*.asenovo.com

# Tenancy migration controls
TENANCY_MIGRATION_ENABLED=true
TENANCY_MIGRATION_INCLUDE_SHARED_SCHEMAS=true
TENANCY_MIGRATION_INCLUDE_DEDICATED_DBS=true
TENANCY_DEFAULT_SHARED_SCHEMA=public
TENANCY_FLYWAY_HISTORY_TABLE=flyway_schema_history
TENANCY_FLYWAY_BASELINE_ON_MIGRATE=true
TENANCY_FLYWAY_CONNECT_RETRIES=1

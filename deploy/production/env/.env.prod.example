TZ=Europe/Istanbul

POSTGRES_DB=asenovo
POSTGRES_USER=asenovo
POSTGRES_PASSWORD=REPLACE_WITH_LONG_RANDOM_DATABASE_PASSWORD

SPRING_PROFILES_ACTIVE=prod

JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
QR_SECRET_KEY=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
QR_BASE_URL=https://api.asenovo.com

CORS_ALLOWED_ORIGINS=https://asenovo.com,https://www.asenovo.com,https://app.asenovo.com,https://*.asenovo.com
VITE_API_BASE_URL=/api

FILE_STORAGE_TYPE=local
FILE_STORAGE_LOCAL_DIR=/app/uploads

TENANCY_MIGRATION_ENABLED=true
TENANCY_MIGRATION_INCLUDE_SHARED_SCHEMAS=true
TENANCY_MIGRATION_INCLUDE_DEDICATED_DBS=true
TENANCY_DEFAULT_SHARED_SCHEMA=public
TENANCY_FLYWAY_HISTORY_TABLE=flyway_schema_history
TENANCY_FLYWAY_BASELINE_ON_MIGRATE=true
TENANCY_FLYWAY_CONNECT_RETRIES=3

ASENOVO_DOCS_ENABLED=false
ASENOVO_MARKETING_ENVIRONMENT=prod
ASENOVO_MARKETING_MAIL_ENABLED=false
ASENOVO_MARKETING_APP_BASE_DOMAIN=asenovo.com
ASENOVO_MARKETING_APP_URL_TEMPLATE=https://{tenant}.asenovo.com/login
ASENOVO_MARKETING_SUPPORT_EMAIL=support@asenovo.com
ASENOVO_MARKETING_FROM_EMAIL=no-reply@asenovo.com

SMTP_HOST=
SMTP_PORT=587
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=
MAIL_FROM=no-reply@asenovo.com
